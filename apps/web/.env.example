# Copie para apps/web/.env.local e preencha.
# Local: após `pnpm exec supabase start`, use `pnpm exec supabase status` para URL e chaves.

NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Nunca exponha a service_role no frontend — apenas em Edge Functions / servidor seguro.
