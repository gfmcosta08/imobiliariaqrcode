# Copie para apps/web/.env.local e preencha.
# Local: após `pnpm exec supabase start`, use `pnpm exec supabase status` para URL e chaves.

NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Nunca exponha a service_role no frontend — apenas em Edge Functions / servidor seguro.
# Para testar QR no app, NEXT_PUBLIC_SUPABASE_URL deve apontar para o mesmo projeto onde rodaram as migrations.

# Servidor (cron, POST /api/public/lead): nunca no bundle do browser — só Vercel/Node.
# CRON_SECRET=...
# SUPABASE_SERVICE_ROLE_KEY=...

# URL pública do app (usada em links de redirect do Stripe e mensagens WhatsApp)
# NEXT_PUBLIC_APP_URL=https://seu-dominio.com.br

# ── Stripe ────────────────────────────────────────────────────────────────────
# Obtenha em https://dashboard.stripe.com/apikeys
# STRIPE_SECRET_KEY=sk_live_...          (produção)  sk_test_... (testes)
# STRIPE_WEBHOOK_SECRET=whsec_...        (Stripe Dashboard → Webhooks → Signing secret)
#
# IDs dos preços criados no Stripe Dashboard (Produtos → Preços)
# STRIPE_PRICE_SOLO=price_...            pagamento único R$ 150 (120 dias)
# STRIPE_PRICE_PRO=price_...             recorrente mensal R$ 500
# STRIPE_PRICE_PREMIUM=price_...         recorrente mensal R$ 1.000
#
# Endpoint do webhook a registrar no Stripe Dashboard:
#   https://seu-dominio.com.br/api/webhooks/stripe
# Eventos necessários:
#   checkout.session.completed
#   invoice.payment_succeeded
#   invoice.payment_failed
#   customer.subscription.deleted
#   customer.subscription.updated
